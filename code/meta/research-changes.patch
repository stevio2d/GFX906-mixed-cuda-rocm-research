+    GGML_ASSERT(begin1 >= 0);
+    GGML_ASSERT(ne1 >= 0);
+    GGML_ASSERT(begin1 + ne1 <= src->ne[1]);
+
+    return ggml_view_4d(
+            ctx,
+            src,
+            src->ne[0],
+            ne1,
+            src->ne[2],
+            src->ne[3],
+            src->nb[1],
+            src->nb[2],
+            src->nb[3],
+            begin1 * src->nb[1]);
+}
