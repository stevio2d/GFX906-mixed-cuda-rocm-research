+    for (int id = 0; id < device_count; ++id) {
+        total_compact_rows += dev[id].compact_rows;
+    }
+    GGML_ASSERT(total_compact_rows == ne_get_rows);
+
+    for (int id = 0; id < ggml_backend_cuda_get_device_count(); ++id) {
+        if (dev[id].compact_rows == 0) {
+            continue;
+        }
+
+        ggml_cuda_set_device(main_device);
+        const int32_t * ids_to_sorted = ids_to_sorted_main + dev[id].compact_offset;
+        dev[id].dst_rows_for_scatter = dst_rows_main + dev[id].compact_offset;
+        char * src1_sorted_main = dev[id].src1_sorted_main_alloc.alloc(ctx.pool(main_device), dev[id].compact_rows*ne10*ts_src1_sorted);
+        get_rows_cuda(src1->data, src1->type, ids_to_sorted, src1_sorted_main, src1->type,
+            ne10, nb11, nb12, nb13,
+            dev[id].compact_rows, 1, 1, sizeof(int32_t), dev[id].compact_rows*sizeof(int32_t), dev[id].compact_rows*sizeof(int32_t),
+            ne10*ts_src1_sorted, dev[id].compact_rows*ne10*ts_src1_sorted, dev[id].compact_rows*ne10*ts_src1_sorted, main_stream);
+        CUDA_CHECK(cudaGetLastError());
+
+        ggml_cuda_set_device(id);
+        cudaStream_t stream = ctx.stream(id, stream_no);
+
+        char * src1_sorted = src1_sorted_main;
+        if (id != main_device) {
+            src1_sorted = dev[id].src1_sorted_alloc.alloc(ctx.pool(id), dev[id].compact_rows*ne10*ts_src1_sorted);
+            ggml_cuda_set_device(main_device);
+            CUDA_CHECK(cudaEventRecord(src0_extra->events[main_device][stream_no], main_stream));
+            ggml_cuda_set_device(id);
+            CUDA_CHECK(cudaStreamWaitEvent(stream, src0_extra->events[main_device][stream_no], 0));
+            CUDA_CHECK(cudaMemcpyPeerAsync(src1_sorted, id, src1_sorted_main, main_device,
+                dev[id].compact_rows*ne10*ts_src1_sorted, stream));
+        }
+        dev[id].src1_data = src1_sorted;
+        float * dst_sorted = dev[id].dst_sorted_alloc.alloc(ctx.pool(id), dev[id].compact_rows*ne0);
+        int32_t * ids_dst_local = dev[id].ids_dst_local_alloc.alloc(ctx.pool(id), dev[id].compact_rows);
+        int32_t * expert_bounds_local = dev[id].expert_bounds_local_alloc.alloc(ctx.pool(id), dev[id].expert_bounds_local_host.size());
+        CUDA_CHECK(cudaMemcpyAsync(ids_dst_local, dev[id].ids_dst_local_host.data(), dev[id].compact_rows*sizeof(int32_t), cudaMemcpyHostToDevice, stream));
+        CUDA_CHECK(cudaMemcpyAsync(expert_bounds_local, dev[id].expert_bounds_local_host.data(),
+            dev[id].expert_bounds_local_host.size()*sizeof(int32_t), cudaMemcpyHostToDevice, stream));
+
+        ggml_tensor src0_local = *src0;
+        src0_local.ne[2]    = dev[id].expert_high - dev[id].expert_low;
+        src0_local.ne[3]    = 1;
+        src0_local.nb[3]    = src0_local.ne[2] * src0_local.nb[2];
+        src0_local.op       = GGML_OP_VIEW;
+        src0_local.view_src = dst->src[0];
+        src0_local.data     = (char *) src0_extra->data_device[id];
+
+        ggml_tensor src1_compact;
+        memset(&src1_compact, 0, sizeof(src1_compact));
+        src1_compact.buffer = src1->buffer;
+        src1_compact.type   = src1->type;
+        src1_compact.ne[0]  = ne10;
+        src1_compact.ne[1]  = dev[id].compact_rows;
+        src1_compact.ne[2]  = 1;
+        src1_compact.ne[3]  = 1;
+        src1_compact.nb[0]  = ts_src1_sorted;
+        src1_compact.nb[1]  = src1_compact.ne[0] * src1_compact.nb[0];
+        src1_compact.nb[2]  = src1_compact.ne[1] * src1_compact.nb[1];
+        src1_compact.nb[3]  = src1_compact.ne[2] * src1_compact.nb[2];
+        src1_compact.data   = (void *) src1_sorted;
+
+        ggml_tensor dst_compact;
+        memset(&dst_compact, 0, sizeof(dst_compact));
+        dst_compact.buffer = dst->buffer;
+        dst_compact.type   = dst->type;
+        dst_compact.ne[0]  = ne0;
+        dst_compact.ne[1]  = dev[id].compact_rows;
+        dst_compact.ne[2]  = 1;
+        dst_compact.ne[3]  = 1;
+        dst_compact.nb[0]  = ts_dst_sorted;
+        dst_compact.nb[1]  = dst_compact.ne[0] * dst_compact.nb[0];
+        dst_compact.nb[2]  = dst_compact.ne[1] * dst_compact.nb[1];
+        dst_compact.nb[3]  = dst_compact.ne[2] * dst_compact.nb[2];
+        dst_compact.data   = dst_sorted;
+
+        const int saved_device = ctx.device;
+        ctx.device = id;
+        ggml_cuda_set_device(id);
+        ggml_cuda_mul_mat_q_precompacted_ids(ctx, &src0_local, &src1_compact, ids_dst_local, expert_bounds_local, &dst_compact,
+            src1, ids, dev[id].expert_low, dev[id].expert_high);
+        CUDA_CHECK(cudaGetLastError());
+        ctx.device = saved_device;
+
+        if (id != main_device) {
+            ggml_cuda_set_device(main_device);
+            dev[id].dst_for_scatter = dev[id].dst_main_alloc.alloc(ctx.pool(main_device), dev[id].compact_rows*ne0);
+
+            ggml_cuda_set_device(id);
+            CUDA_CHECK(cudaMemcpyPeerAsync(dev[id].dst_for_scatter, main_device, dst_sorted, id,
+                dev[id].compact_rows*ne0*sizeof(float), stream));
+            CUDA_CHECK(cudaEventRecord(src0_extra->events[id][stream_no], stream));
