+static bool ggml_cuda_split_buffer_env_weights(std::array<float, GGML_CUDA_MAX_DEVICES> & weights) {
+    const char * value = getenv("GGML_CUDA_SPLIT_BUFFER_WEIGHTS");
+    if (value == nullptr || value[0] == '\0') {
+        return false;
+    }
+
+    weights.fill(0.0f);
+
+    const char * p = value;
+    int id = 0;
+    while (*p != '\0' && id < ggml_backend_cuda_get_device_count()) {
+        while (*p == ',' || *p == '/' || *p == ' ' || *p == '\t') {
+            ++p;
+        }
+        if (*p == '\0') {
+            break;
+        }
+
+        char * end = nullptr;
+        const float parsed = strtof(p, &end);
+        if (end == p) {
+            return false;
+        }
+
+        weights[id++] = parsed > 0.0f ? parsed : 0.0f;
+        p = end;
+    }
+
+    float sum = 0.0f;
+    for (int i = 0; i < ggml_backend_cuda_get_device_count(); ++i) {
+        sum += weights[i];
+    }
+
+    if (sum <= 0.0f) {
+        GGML_LOG_WARN("GGML_CUDA_SPLIT_BUFFER_WEIGHTS='%s' has no positive entries, ignoring\n", value);
+        return false;
+    }
+
+    return true;
+}
+
+static std::array<float, GGML_CUDA_MAX_DEVICES> ggml_cuda_split_weights_to_scan(
+        const std::array<float, GGML_CUDA_MAX_DEVICES> & weights) {
+    std::array<float, GGML_CUDA_MAX_DEVICES> scan = {};
+
+    float split_sum = 0.0f;
+    for (int i = 0; i < ggml_backend_cuda_get_device_count(); ++i) {
+        scan[i] = split_sum;
+        split_sum += weights[i];
+    }
+    for (int i = 0; i < ggml_backend_cuda_get_device_count(); ++i) {
+        scan[i] /= split_sum;
+    }
+
+    return scan;
+}
