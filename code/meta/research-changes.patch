+llama_minimax_prompt_attn_plan llama_model::build_minimax_prompt_attn_plan(const llama_cparams & cparams) const {
+    llama_minimax_prompt_attn_plan plan;
+    plan.layer_rank.assign(hparams.n_layer, -1);
+
+    if (arch != LLM_ARCH_MINIMAX_M2 || cparams.minimax_fattn_devices.empty()) {
+        return plan;
+    }
+
+    auto resolve_selected_device = [&](const std::string & value, const char * arg_name) -> ggml_backend_dev_t {
+        int target_device = -1;
+
+        try {
+            size_t pos = 0;
+            const int idev = std::stoi(value, &pos);
+            if (pos == value.size()) {
+                if (idev < 0 || idev >= int(devices.size())) {
+                    throw std::runtime_error(format(
+                        "%s: %s index %d is out of range for %zu selected devices",
+                        __func__, arg_name, idev, devices.size()));
+                }
+                target_device = idev;
+            }
+        } catch (const std::invalid_argument &) {
+            // resolve by selected device name below
+        } catch (const std::out_of_range &) {
+            throw std::runtime_error(format("%s: %s index is out of range", __func__, arg_name));
+        }
+
+        if (target_device < 0) {
+            for (size_t i = 0; i < devices.size(); ++i) {
+                if (value == ggml_backend_dev_name(devices[i].dev)) {
+                    target_device = int(i);
+                    break;
+                }
+            }
+        }
+
+        if (target_device < 0) {
+            std::string available;
+            for (const auto & dev : devices) {
+                if (!available.empty()) {
+                    available += ", ";
+                }
+                available += ggml_backend_dev_name(dev.dev);
+            }
+            throw std::runtime_error(format(
+                "%s: %s '%s' is not a selected device (available: %s)",
+                __func__, arg_name, value.c_str(), available.c_str()));
+        }
+
+        return devices[target_device].dev;
+    };
+
+    size_t pos = 0;
+    while (pos <= cparams.minimax_fattn_devices.size()) {
+        const size_t comma = cparams.minimax_fattn_devices.find(',', pos);
+        std::string value = cparams.minimax_fattn_devices.substr(
+            pos, comma == std::string::npos ? std::string::npos : comma - pos);
+        value.erase(0, value.find_first_not_of(" \t"));
+        value.erase(value.find_last_not_of(" \t") + 1);
+        if (value.empty()) {
+            throw std::runtime_error("--minimax-fattn-devices contains an empty device entry");
+        }
+
+        plan.schedule_devs.push_back(resolve_selected_device(value, "--minimax-fattn-devices"));
+        if (comma == std::string::npos) {
+            break;
+        }
+        pos = comma + 1;
+    }
+
+    if (!cparams.minimax_fattn_device_weights.empty()) {
+        if (cparams.minimax_fattn_device_weights.size() != plan.schedule_devs.size()) {
+            throw std::runtime_error(format(
+                "%s: --minimax-fattn-device-weights has %zu entries, but --minimax-fattn-devices resolved to %zu device(s)",
+                __func__, cparams.minimax_fattn_device_weights.size(), plan.schedule_devs.size()));
+        }
+
+        std::vector<ggml_backend_dev_t> weighted_schedule;
+        for (size_t i = 0; i < plan.schedule_devs.size(); ++i) {
+            const int32_t weight = cparams.minimax_fattn_device_weights[i];
+            for (int32_t rep = 0; rep < weight; ++rep) {
+                weighted_schedule.push_back(plan.schedule_devs[i]);
+            }
+        }
+
+        if (weighted_schedule.empty()) {
+            throw std::runtime_error("--minimax-fattn-device-weights must contain at least one positive value");
+        }
+
+        plan.schedule_devs = std::move(weighted_schedule);
+    }
+
+    int32_t rank = 0;
+    for (int32_t il = 0; il < hparams.n_layer; ++il) {
+        auto * dev_layer_cur = dev_layer(il);
+        auto * reg_layer = ggml_backend_dev_backend_reg(dev_layer_cur);
+        const bool rocm_layer = reg_layer != nullptr && strcmp(ggml_backend_reg_name(reg_layer), "ROCm") == 0;
+        const bool layer_selected = cparams.minimax_fattn_layers.empty() ||
+            std::find(cparams.minimax_fattn_layers.begin(), cparams.minimax_fattn_layers.end(), il) != cparams.minimax_fattn_layers.end();
+        if (rocm_layer && layer_selected) {
+            plan.layer_rank[il] = rank++;
+        }
+    }
+
+    return plan;
+}
