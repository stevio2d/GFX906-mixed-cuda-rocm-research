+static bool ggml_cuda_mul_mat_id_split_expert_axis_fused_moe_out(
+        ggml_backend_cuda_context & ctx,
+        ggml_tensor * gate,
+        ggml_tensor * up,
+        ggml_tensor * glu,
+        ggml_tensor * down,
+        ggml_tensor * weighted,
+        ggml_tensor * moe_out) {
+    if (!ggml_cuda_split_fused_moe_out_enabled()) {
+        return false;
+    }
+
+    if (gate->op != GGML_OP_MUL_MAT_ID || up->op != GGML_OP_MUL_MAT_ID ||
+        glu->op != GGML_OP_GLU || down->op != GGML_OP_MUL_MAT_ID || weighted->op != GGML_OP_MUL) {
+        return false;
+    }
+
+    ggml_tensor * gate_node = nullptr;
+    ggml_tensor * up_node   = nullptr;
+    if (glu->src[0] == gate && glu->src[1] == up) {
+        gate_node = gate;
+        up_node   = up;
+    } else if (glu->src[0] == up && glu->src[1] == gate) {
+        gate_node = up;
+        up_node   = gate;
+    } else {
+        return false;
+    }
+
+    if (down->src[1] != glu) {
+        return false;
+    }
+
+    ggml_tensor * weights = nullptr;
+    if (weighted->src[0] == down) {
+        weights = weighted->src[1];
+    } else if (weighted->src[1] == down) {
+        weights = weighted->src[0];
+    } else {
+        return false;
+    }
+
+    const ggml_tensor * gate_src0 = gate_node->src[0];
+    const ggml_tensor * up_src0   = up_node->src[0];
+    const ggml_tensor * down_src0 = down->src[0];
+    const ggml_tensor * src1      = up_node->src[1];
+    const ggml_tensor * ids       = up_node->src[2];
+
+    if (gate_node->src[1] != src1 || down->src[2] != ids || gate_node->src[2] != ids) {
+        return false;
+    }
+
+    if (src1->type != GGML_TYPE_F32 || ids->type != GGML_TYPE_I32 || weights->type != GGML_TYPE_F32 ||
+        moe_out->type != GGML_TYPE_F32 || down->type != GGML_TYPE_F32) {
+        return false;
+    }
+
+    if (!ggml_cuda_split_expert_axis_tensor(gate_src0) ||
+        !ggml_cuda_split_expert_axis_tensor(up_src0) ||
+        !ggml_cuda_split_expert_axis_tensor(down_src0)) {
+        return false;
+    }
+
+    ggml_tensor_extra_gpu * gate_extra = (ggml_tensor_extra_gpu *) gate_src0->extra;
+    ggml_tensor_extra_gpu * up_extra   = (ggml_tensor_extra_gpu *) up_src0->extra;
+    ggml_tensor_extra_gpu * down_extra = (ggml_tensor_extra_gpu *) down_src0->extra;
+    if (gate_extra == nullptr || up_extra == nullptr || down_extra == nullptr) {
+        return false;
+    }
+
+    GGML_ASSERT(ids->ne[0] > 0);
+
+    const int main_device = ctx.device;
+    const int stream_no   = ctx.curr_stream_no;
+    const int64_t n_expert_used = ids->ne[0];
+    const int64_t n_tokens = ids->ne[1];
+    const int64_t ne_get_rows = n_tokens*n_expert_used;
+    const int64_t hidden = moe_out->ne[0];
+    const int64_t ff = down->src[1]->ne[0];
+    const size_t ts_src1 = ggml_type_size(src1->type);
+    const int device_count = ggml_backend_cuda_get_device_count();
+
+    ggml_backend_cuda_split_buffer_type_context * gate_buft_ctx =
+        (ggml_backend_cuda_split_buffer_type_context *) gate_src0->buffer->buft->context;
+
+    ggml_cuda_set_device(main_device);
+    cudaStream_t main_stream = ctx.stream(main_device, stream_no);
+
+    ggml_cuda_pool_alloc<int32_t> ids_to_sorted_main_alloc;
+    ggml_cuda_pool_alloc<int32_t> dst_rows_main_alloc;
+    ggml_cuda_pool_alloc<int32_t> expert_bounds_main_alloc;
+    int32_t * ids_to_sorted_main = ids_to_sorted_main_alloc.alloc(ctx.pool(main_device), ne_get_rows);
+    int32_t * dst_rows_main = dst_rows_main_alloc.alloc(ctx.pool(main_device), ne_get_rows);
+    int32_t * expert_bounds_main = expert_bounds_main_alloc.alloc(ctx.pool(main_device), gate_src0->ne[2] + 1);
+
+    const int si1  = static_cast<int>(ids->nb[1] / ggml_type_size(ids->type));
+    const int sis1 = static_cast<int>(src1->nb[2] / src1->nb[1]);
+    GGML_ASSERT(sis1 > 0);
+
+    ggml_cuda_launch_mm_ids_helper((const int32_t *) ids->data, ids_to_sorted_main, dst_rows_main, expert_bounds_main,
+        static_cast<int>(gate_src0->ne[2]), static_cast<int>(n_tokens), static_cast<int>(n_expert_used), static_cast<int>(src1->ne[1]), si1, sis1, main_stream);
+    CUDA_CHECK(cudaGetLastError());
+
+    std::vector<int32_t> expert_bounds_host(gate_src0->ne[2] + 1);
+    CUDA_CHECK(cudaMemcpyAsync(expert_bounds_host.data(), expert_bounds_main, (gate_src0->ne[2] + 1)*sizeof(int32_t), cudaMemcpyDeviceToHost, main_stream));
+    CUDA_CHECK(cudaStreamSynchronize(main_stream));
+
+    struct dev_data {
+        int64_t expert_low = 0;
+        int64_t expert_high = 0;
+        int64_t compact_offset = 0;
+        int64_t compact_rows = 0;
+
+        std::vector<int32_t> tokens_per_expert;
+        std::vector<int32_t> ids_dst_local_host;
+        std::vector<int32_t> expert_bounds_local_host;
+
+        ggml_cuda_pool_alloc<char> gate_src1_sorted_main_alloc;
+        ggml_cuda_pool_alloc<char> gate_src1_sorted_alloc;
+        ggml_cuda_pool_alloc<float> weights_sorted_main_alloc;
+        ggml_cuda_pool_alloc<float> weights_sorted_alloc;
+        ggml_cuda_pool_alloc<int32_t> ids_dst_local_alloc;
+        ggml_cuda_pool_alloc<int32_t> expert_bounds_local_alloc;
+        ggml_cuda_pool_alloc<int32_t> dst_rows_local_alloc;
+        ggml_cuda_pool_alloc<float> gate_sorted_alloc;
+        ggml_cuda_pool_alloc<float> up_sorted_alloc;
+        ggml_cuda_pool_alloc<float> glu_sorted_alloc;
+        ggml_cuda_pool_alloc<float> down_sorted_alloc;
+        ggml_cuda_pool_alloc<float> partial_sorted_alloc;
+        ggml_cuda_pool_alloc<float> partial_main_alloc;
+
+        const char * src1_data = nullptr;
+        const float * weights_data = nullptr;
+        int32_t * dst_rows_local = nullptr;
+        float * partial_for_merge = nullptr;
+    };
+
+    std::array<dev_data, GGML_CUDA_MAX_DEVICES> dev{};
+
+    auto init_split = [&](ggml_backend_cuda_split_buffer_type_context * buft_ctx, int id, int64_t & low, int64_t & high) {
+        get_expert_split(&low, &high, gate_src0, buft_ctx->tensor_split, id);
+    };
+
+    int64_t total_compact_rows = 0;
+    for (int id = 0; id < device_count; ++id) {
+        init_split(gate_buft_ctx, id, dev[id].expert_low, dev[id].expert_high);
+        const int64_t nexpert_split = dev[id].expert_high - dev[id].expert_low;
+        if (nexpert_split == 0) {
+            continue;
+        }
+
+        dev[id].tokens_per_expert.assign(nexpert_split, 0);
+        dev[id].expert_bounds_local_host.assign(nexpert_split + 1, 0);
+        for (int64_t ie = dev[id].expert_low; ie < dev[id].expert_high; ++ie) {
+            dev[id].tokens_per_expert[ie - dev[id].expert_low] = expert_bounds_host[ie + 1] - expert_bounds_host[ie];
+        }
+        dev[id].compact_offset = expert_bounds_host[dev[id].expert_low];
+        dev[id].compact_rows = expert_bounds_host[dev[id].expert_high] - dev[id].compact_offset;
+        dev[id].ids_dst_local_host.resize(dev[id].compact_rows);
+        for (int64_t i = 0; i < dev[id].compact_rows; ++i) {
+            dev[id].ids_dst_local_host[i] = i;
+        }
+        for (size_t ilocal = 0; ilocal < dev[id].tokens_per_expert.size(); ++ilocal) {
+            dev[id].expert_bounds_local_host[ilocal + 1] =
+                dev[id].expert_bounds_local_host[ilocal] + dev[id].tokens_per_expert[ilocal];
+        }
+        total_compact_rows += dev[id].compact_rows;
+    }
+
+    GGML_ASSERT(total_compact_rows == ne_get_rows);
+
+    auto make_local_src0 = [](const ggml_tensor * global_src0, ggml_tensor_extra_gpu * extra, int id, int64_t expert_low, int64_t expert_high) {
+        ggml_tensor local = *global_src0;
+        local.ne[2]    = expert_high - expert_low;
+        local.ne[3]    = 1;
+        local.nb[3]    = local.ne[2] * local.nb[2];
+        local.op       = GGML_OP_VIEW;
+        local.view_src = (ggml_tensor *) global_src0;
+        local.data     = (char *) extra->data_device[id];
+        return local;
+    };
+
+    auto make_compact_tensor = [](const ggml_tensor * like, ggml_type type, int64_t ne0, int64_t ne1, void * data) {
+        ggml_tensor compact = *like;
+        compact.type  = type;
+        compact.ne[0] = ne0;
+        compact.ne[1] = ne1;
+        compact.ne[2] = 1;
+        compact.ne[3] = 1;
+        compact.nb[0] = ggml_type_size(type);
+        compact.nb[1] = compact.ne[0] * compact.nb[0];
+        compact.nb[2] = compact.ne[1] * compact.nb[1];
+        compact.nb[3] = compact.ne[2] * compact.nb[2];
+        compact.data  = data;
+        return compact;
+    };
+
+    for (int id = 0; id < device_count; ++id) {
+        if (dev[id].compact_rows == 0) {
+            continue;
+        }
+
+        ggml_cuda_set_device(main_device);
+        const int32_t * ids_to_sorted = ids_to_sorted_main + dev[id].compact_offset;
+        const int32_t * dst_rows_host = dst_rows_main + dev[id].compact_offset;
+
+        char * src1_sorted_main = dev[id].gate_src1_sorted_main_alloc.alloc(ctx.pool(main_device), dev[id].compact_rows*src1->ne[0]*ts_src1);
+        get_rows_cuda(src1->data, src1->type, ids_to_sorted, src1_sorted_main, src1->type,
+            src1->ne[0], src1->nb[1], src1->nb[2], src1->nb[3],
+            dev[id].compact_rows, 1, 1, sizeof(int32_t), dev[id].compact_rows*sizeof(int32_t), dev[id].compact_rows*sizeof(int32_t),
+            src1->ne[0]*ts_src1, dev[id].compact_rows*src1->ne[0]*ts_src1, dev[id].compact_rows*src1->ne[0]*ts_src1, main_stream);
+        CUDA_CHECK(cudaGetLastError());
+
+        float * weights_sorted_main = dev[id].weights_sorted_main_alloc.alloc(ctx.pool(main_device), dev[id].compact_rows);
+        ggml_cuda_gather_rows_f32((const float *) weights->data, dst_rows_host, weights_sorted_main, dev[id].compact_rows, main_stream);
+
+        ggml_cuda_set_device(id);
+        cudaStream_t stream = ctx.stream(id, stream_no);
+
+        const char * src1_sorted = src1_sorted_main;
+        if (id != main_device) {
+            src1_sorted = dev[id].gate_src1_sorted_alloc.alloc(ctx.pool(id), dev[id].compact_rows*src1->ne[0]*ts_src1);
+            ggml_cuda_set_device(main_device);
+            CUDA_CHECK(cudaEventRecord(down_extra->events[main_device][stream_no], main_stream));
+            ggml_cuda_set_device(id);
+            CUDA_CHECK(cudaStreamWaitEvent(stream, down_extra->events[main_device][stream_no], 0));
+            CUDA_CHECK(cudaMemcpyPeerAsync((void *) src1_sorted, id, src1_sorted_main, main_device,
+                dev[id].compact_rows*src1->ne[0]*ts_src1, stream));
+        }
+        dev[id].src1_data = src1_sorted;
+
+        float * weights_sorted = weights_sorted_main;
+        if (id != main_device) {
+            weights_sorted = dev[id].weights_sorted_alloc.alloc(ctx.pool(id), dev[id].compact_rows);
+            CUDA_CHECK(cudaMemcpyPeerAsync(weights_sorted, id, weights_sorted_main, main_device,
+                dev[id].compact_rows*sizeof(float), stream));
+        }
+        dev[id].weights_data = weights_sorted;
+
+        int32_t * ids_dst_local = dev[id].ids_dst_local_alloc.alloc(ctx.pool(id), dev[id].compact_rows);
+        int32_t * expert_bounds_local = dev[id].expert_bounds_local_alloc.alloc(ctx.pool(id), dev[id].expert_bounds_local_host.size());
+        int32_t * dst_rows_local = dev[id].dst_rows_local_alloc.alloc(ctx.pool(id), dev[id].compact_rows);
+        CUDA_CHECK(cudaMemcpyAsync(ids_dst_local, dev[id].ids_dst_local_host.data(), dev[id].compact_rows*sizeof(int32_t), cudaMemcpyHostToDevice, stream));
+        CUDA_CHECK(cudaMemcpyAsync(expert_bounds_local, dev[id].expert_bounds_local_host.data(),
+            dev[id].expert_bounds_local_host.size()*sizeof(int32_t), cudaMemcpyHostToDevice, stream));
+        if (id == main_device) {
+            CUDA_CHECK(cudaMemcpyAsync(dst_rows_local, dst_rows_host, dev[id].compact_rows*sizeof(int32_t), cudaMemcpyDeviceToDevice, stream));
+        } else {
+            CUDA_CHECK(cudaMemcpyPeerAsync(dst_rows_local, id, (void *) dst_rows_host, main_device,
+                dev[id].compact_rows*sizeof(int32_t), stream));
+        }
+        dev[id].dst_rows_local = dst_rows_local;
+
+        ggml_tensor gate_src0_local = make_local_src0(gate_src0, gate_extra, id, dev[id].expert_low, dev[id].expert_high);
+        ggml_tensor up_src0_local   = make_local_src0(up_src0,   up_extra,   id, dev[id].expert_low, dev[id].expert_high);
+        ggml_tensor down_src0_local = make_local_src0(down_src0, down_extra, id, dev[id].expert_low, dev[id].expert_high);
+
+        const int saved_device = ctx.device;
+        ctx.device = id;
+        ggml_cuda_set_device(id);
+        float * gate_sorted = dev[id].gate_sorted_alloc.alloc(ctx.pool(id), dev[id].compact_rows*ff);
+        float * up_sorted   = dev[id].up_sorted_alloc.alloc(ctx.pool(id), dev[id].compact_rows*ff);
+        float * glu_sorted  = dev[id].glu_sorted_alloc.alloc(ctx.pool(id), dev[id].compact_rows*ff);
+        float * down_sorted = dev[id].down_sorted_alloc.alloc(ctx.pool(id), dev[id].compact_rows*hidden);
+        float * partial_sum = dev[id].partial_sorted_alloc.alloc(ctx.pool(id), n_tokens*hidden);
+        CUDA_CHECK(cudaMemsetAsync(partial_sum, 0, n_tokens*hidden*sizeof(float), stream));
+
+        ggml_tensor src1_compact = make_compact_tensor(src1, src1->type, src1->ne[0], dev[id].compact_rows, (void *) dev[id].src1_data);
+        ggml_tensor gate_compact = make_compact_tensor(gate, GGML_TYPE_F32, ff, dev[id].compact_rows, gate_sorted);
+        ggml_tensor up_compact   = make_compact_tensor(up,   GGML_TYPE_F32, ff, dev[id].compact_rows, up_sorted);
+
+        ggml_cuda_mul_mat_q_precompacted_ids(ctx, &gate_src0_local, &src1_compact, ids_dst_local, expert_bounds_local, &gate_compact,
+            src1, ids, dev[id].expert_low, dev[id].expert_high);
+        ggml_cuda_mul_mat_q_precompacted_ids(ctx, &up_src0_local, &src1_compact, ids_dst_local, expert_bounds_local, &up_compact,
+            src1, ids, dev[id].expert_low, dev[id].expert_high);
+
+        ggml_tensor glu_compact = make_compact_tensor(glu, GGML_TYPE_F32, ff, dev[id].compact_rows, glu_sorted);
+        glu_compact.op = GGML_OP_GLU;
+        glu_compact.src[0] = &gate_compact;
+        glu_compact.src[1] = &up_compact;
+        switch (ggml_get_glu_op(glu)) {
+            case GGML_GLU_OP_REGLU:       ggml_cuda_op_reglu(ctx, &glu_compact); break;
+            case GGML_GLU_OP_GEGLU:       ggml_cuda_op_geglu(ctx, &glu_compact); break;
+            case GGML_GLU_OP_SWIGLU:      ggml_cuda_op_swiglu(ctx, &glu_compact); break;
+            case GGML_GLU_OP_SWIGLU_OAI:  ggml_cuda_op_swiglu_oai(ctx, &glu_compact); break;
+            case GGML_GLU_OP_GEGLU_ERF:   ggml_cuda_op_geglu_erf(ctx, &glu_compact); break;
+            case GGML_GLU_OP_GEGLU_QUICK: ggml_cuda_op_geglu_quick(ctx, &glu_compact); break;
+            default: ctx.device = saved_device; return false;
+        }
+
+        ggml_tensor down_compact = make_compact_tensor(down, GGML_TYPE_F32, hidden, dev[id].compact_rows, down_sorted);
+        ggml_cuda_mul_mat_q_precompacted_ids(ctx, &down_src0_local, &glu_compact, ids_dst_local, expert_bounds_local, &down_compact,
+            &glu_compact, ids, dev[id].expert_low, dev[id].expert_high);
+
+        ggml_cuda_moe_weighted_accum_tokens_f32(down_sorted, dev[id].weights_data, dev[id].dst_rows_local, partial_sum, hidden, dev[id].compact_rows,
+            (int) n_expert_used, stream);
+
+        ctx.device = saved_device;
+
+        if (id != main_device) {
+            ggml_cuda_set_device(main_device);
+            dev[id].partial_for_merge = dev[id].partial_main_alloc.alloc(ctx.pool(main_device), n_tokens*hidden);
+            ggml_cuda_set_device(id);
+            CUDA_CHECK(cudaMemcpyPeerAsync(dev[id].partial_for_merge, main_device, partial_sum, id, n_tokens*hidden*sizeof(float), stream));
+            CUDA_CHECK(cudaEventRecord(down_extra->events[id][stream_no], stream));
+        } else {
+            dev[id].partial_for_merge = partial_sum;
+        }
+    }
+
+    ctx.device = main_device;
+    ggml_cuda_set_device(main_device);
+    bool have_base_partial = false;
+    for (int id = 0; id < device_count; ++id) {
+        if (dev[id].compact_rows == 0) {
+            continue;
+        }
+        if (id != main_device) {
+            CUDA_CHECK(cudaStreamWaitEvent(main_stream, down_extra->events[id][stream_no], 0));
+        }
+        if (!have_base_partial) {
+            CUDA_CHECK(cudaMemcpyAsync(moe_out->data, dev[id].partial_for_merge, n_tokens*hidden*sizeof(float), cudaMemcpyDeviceToDevice, main_stream));
+            have_base_partial = true;
+        } else {
+            ggml_cuda_add_f32(dev[id].partial_for_merge, (float *) moe_out->data, n_tokens*hidden, main_stream);
+        }
+    }
+
+    if (!have_base_partial) {
+        CUDA_CHECK(cudaMemsetAsync(moe_out->data, 0, n_tokens*hidden*sizeof(float), main_stream));
+    }
+
+    return true;
+}
+
+static void ggml_cuda_mul_mat_id_split(ggml_backend_cuda_context & ctx, ggml_tensor * dst) {
+    const ggml_tensor * src0 = dst->src[0];
+    const ggml_tensor * src1 = dst->src[1];
+    const ggml_tensor * ids  = dst->src[2];
+
+    GGML_ASSERT(src1->type == GGML_TYPE_F32);
+    GGML_ASSERT(dst->type  == GGML_TYPE_F32);
+    GGML_ASSERT(ids && ids->type == GGML_TYPE_I32);
+    GGML_ASSERT(ggml_is_quantized(src0->type));
+    GGML_ASSERT(ggml_backend_buft_is_cuda_split(src0->buffer->buft));
+
+    if (ggml_cuda_split_expert_axis_tensor(src0)) {
+        ggml_cuda_mul_mat_id_split_expert_axis(ctx, dst);
+        return;
+    }
+
+    GGML_TENSOR_BINARY_OP_LOCALS
+
+    GGML_ASSERT(ne03 == 1);
+    GGML_ASSERT(ne13 == 1);
+    GGML_ASSERT(ne3  == 1);
+    GGML_ASSERT(nb0  == sizeof(float));
+    GGML_ASSERT(nb1  == ne0*sizeof(float));
+    GGML_ASSERT(nb2  == ne1*nb1);
+    GGML_ASSERT(nb3  == ne2*nb2);
+
+    ggml_backend_cuda_split_buffer_type_context * buft_ctx =
+        (ggml_backend_cuda_split_buffer_type_context *) src0->buffer->buft->context;
+    ggml_tensor_extra_gpu * src0_extra = (ggml_tensor_extra_gpu *) src0->extra;
+
+    const int main_device  = ctx.device;
+    const int stream_no    = ctx.curr_stream_no;
+    const size_t src1_size = ggml_nbytes(src1);
+    const size_t ids_size  = ggml_nbytes(ids);
+    const int64_t dst_rows = ne1*ne2*ne3;
+
+    struct dev_data {
+        int64_t row_low  = 0;
+        int64_t row_high = 0;
+
+        ggml_cuda_pool_alloc<char>  src1_alloc;
+        ggml_cuda_pool_alloc<char>   ids_alloc;
+        ggml_cuda_pool_alloc<float>  dst_alloc;
+
+        ggml_tensor src0_local;
+        ggml_tensor src1_local;
+        ggml_tensor ids_local;
+        ggml_tensor dst_local;
+    };
+
+    dev_data dev[GGML_CUDA_MAX_DEVICES];
+
+    ggml_cuda_set_device(main_device);
+    CUDA_CHECK(cudaEventRecord(src0_extra->events[main_device][stream_no], ctx.stream(main_device, stream_no)));
+
+    for (int id = 0; id < ggml_backend_cuda_get_device_count(); ++id) {
+        get_row_split(&dev[id].row_low, &dev[id].row_high, src0, buft_ctx->tensor_split, id);
+
+        const int64_t row_diff = dev[id].row_high - dev[id].row_low;
+        if (row_diff == 0) {
+            continue;
+        }
+
+        ggml_cuda_set_device(id);
+        cudaStream_t stream = ctx.stream(id, stream_no);
+
+        if (id != main_device) {
+            CUDA_CHECK(cudaStreamWaitEvent(stream, src0_extra->events[main_device][stream_no], 0));
+
+            char * src1_local = dev[id].src1_alloc.alloc(ctx.pool(id), src1_size);
+            char *  ids_local = dev[id].ids_alloc.alloc (ctx.pool(id), ids_size);
+
+            CUDA_CHECK(cudaMemcpyPeerAsync(src1_local, id, src1->data, main_device, src1_size, stream));
+            CUDA_CHECK(cudaMemcpyPeerAsync( ids_local, id,  ids->data, main_device,  ids_size, stream));
+        }
+
+        float * dst_local = dev[id].dst_alloc.alloc(ctx.pool(id), row_diff*dst_rows);
+
+        dev[id].src0_local = *src0;
+        dev[id].src0_local.ne[1] = row_diff;
+        dev[id].src0_local.nb[2] = ggml_cuda_split_plane_stride(src0, row_diff);
+        dev[id].src0_local.nb[3] = src0->ne[2]*dev[id].src0_local.nb[2];
+        dev[id].src0_local.data  = src0_extra->data_device[id];
+
+        dev[id].src1_local = *src1;
+        dev[id].src1_local.data = id == main_device ? src1->data : dev[id].src1_alloc.get();
+
+        dev[id].ids_local = *ids;
+        dev[id].ids_local.data = id == main_device ? ids->data : dev[id].ids_alloc.get();
+
+        dev[id].dst_local = *dst;
+        dev[id].dst_local.ne[0] = row_diff;
+        dev[id].dst_local.nb[0] = sizeof(float);
+        dev[id].dst_local.nb[1] = row_diff*sizeof(float);
+        dev[id].dst_local.nb[2] = dev[id].dst_local.ne[1]*dev[id].dst_local.nb[1];
+        dev[id].dst_local.nb[3] = dev[id].dst_local.ne[2]*dev[id].dst_local.nb[2];
+        dev[id].dst_local.data  = dst_local;
+
+        const int saved_device = ctx.device;
+        ctx.device = id;
+        ggml_cuda_set_device(id);
+        ggml_cuda_mul_mat_q(ctx, &dev[id].src0_local, &dev[id].src1_local, &dev[id].ids_local, &dev[id].dst_local);
+        CUDA_CHECK(cudaGetLastError());
+        ctx.device = saved_device;
+
+        float * dst_full = (float *) dst->data + dev[id].row_low;
+        CUDA_CHECK(ggml_cuda_Memcpy2DPeerAsync(
+            dst_full, main_device, nb1,
+            dst_local, id, row_diff*sizeof(float),
+            row_diff*sizeof(float), dst_rows, stream));
+
+        CUDA_CHECK(cudaEventRecord(src0_extra->events[id][stream_no], stream));
+    }
+
+    ctx.device = main_device;
+    ggml_cuda_set_device(main_device);
+    for (int id = 0; id < ggml_backend_cuda_get_device_count(); ++id) {
+        if (dev[id].row_low == dev[id].row_high) {
