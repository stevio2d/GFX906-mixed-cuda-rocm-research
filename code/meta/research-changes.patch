+template<int stride_tile, int nwarps, int nbatch_fa, bool oob_check>
+static __device__ __forceinline__ void flash_attn_ext_q4_0_load_tile(
+        const char * const __restrict__ KV, half2 * const __restrict__ tile_KV,
+        const int D2, const int64_t stride_KV, const int i_sup, const int k0_h2) {
+    constexpr int warp_size = ggml_cuda_get_physical_warp_size();
+    constexpr int h2_per_chunk = 16/sizeof(half2);
+    const int chunks_per_row = D2 / h2_per_chunk;
+    const half2 zero = make_half2(0.0f, 0.0f);
+
+    auto load = [&] __device__ (const int n) {
+        const int stride_k = 32 >> n;
+        const int k0_start = stride_k == 32 ? 0 : chunks_per_row - chunks_per_row % (2*stride_k);
+        const int k0_stop  =                      chunks_per_row - chunks_per_row % (1*stride_k);
+        const int stride_i = warp_size / stride_k;
+
+        if (k0_start == k0_stop) {
+            return;
+        }
+
+#pragma unroll
+        for (int i0 = 0; i0 < nbatch_fa; i0 += nwarps*stride_i) {
+            const int i = i0 + threadIdx.y*stride_i + (stride_k == warp_size ? 0 : threadIdx.x / stride_k);
+
+            if (i0 + nwarps*stride_i > nbatch_fa && i >= nbatch_fa) {
+                break;
+            }
+
+#pragma unroll
+            for (int k0 = k0_start; k0 < k0_stop; k0 += stride_k) {
+                const int k = k0 + (stride_k == warp_size ? threadIdx.x : threadIdx.x % stride_k);
+                half2 vals[h2_per_chunk];
+
+                if (!oob_check || i < i_sup) {
+                    const char * row = KV + int64_t(i)*stride_KV;
+#pragma unroll
+                    for (int kk = 0; kk < h2_per_chunk; ++kk) {
+                        dequantize_V_q4_0<half, 2>(row, vals + kk, 2*(k0_h2 + k*h2_per_chunk + kk));
+                    }
+                } else {
+#pragma unroll
+                    for (int kk = 0; kk < h2_per_chunk; ++kk) {
+                        vals[kk] = zero;
+                    }
+                }
+
+#pragma unroll
+                for (int kk = 0; kk < h2_per_chunk; ++kk) {
+                    tile_KV[i*stride_tile + k*h2_per_chunk + kk] = vals[kk];
+                }
+            }
+        }
+    };
+
+    ggml_cuda_unroll<6>{}(load);
+}
