+static llama_minimax_attn_subgraph_mode llama_minimax_attn_subgraph_mode_get() {
+    const char * env = getenv("LLAMA_MINIMAX_ATTN_SUBGRAPH");
+    if (env == nullptr || env[0] == '\0' || strcmp(env, "0") == 0) {
+        return llama_minimax_attn_subgraph_mode::OFF;
+    }
+    if (strcmp(env, "postnorm") == 0 || strcmp(env, "post-norm") == 0) {
+        return llama_minimax_attn_subgraph_mode::POSTNORM;
+    }
+    return llama_minimax_attn_subgraph_mode::BROAD;
+}
+
+static bool llama_minimax_attn_subgraph_name(llama_minimax_attn_subgraph_mode mode, const char * name) {
+    if (mode == llama_minimax_attn_subgraph_mode::BROAD && strcmp(name, "attn_norm") == 0) {
+        return true;
+    }
+    if (mode == llama_minimax_attn_subgraph_mode::POSTNORM || mode == llama_minimax_attn_subgraph_mode::BROAD) {
+        return strcmp(name, "Qcur") == 0 ||
+            strcmp(name, "Kcur") == 0 ||
+            strcmp(name, "Vcur") == 0 ||
+            strcmp(name, "Qcur_normed") == 0 ||
+            strcmp(name, "Kcur_normed") == 0 ||
+            strcmp(name, "kqv_out") == 0 ||
+            strcmp(name, LLAMA_TENSOR_NAME_FATTN) == 0;
+    }
+    return false;
+}
