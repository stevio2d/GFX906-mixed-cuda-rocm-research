+static std::string ggml_backend_sched_moe_profile_json_path_for_eval(const std::string & base_path, uint64_t eval_count) {
+    if (base_path.empty() || eval_count <= 1) {
+        return base_path;
+    }
+
+    return base_path + ".eval" + std::to_string(eval_count) + ".json";
+}
