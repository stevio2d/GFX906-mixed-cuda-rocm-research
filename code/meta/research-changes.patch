+static std::vector<int32_t> parse_layer_split(const std::string & value) {
+    const std::regex regex{ R"([,/]+)" };
+    std::sregex_token_iterator it{ value.begin(), value.end(), regex, -1 };
+    std::vector<std::string> split_arg{ it, {} };
+    if (split_arg.empty()) {
+        throw std::invalid_argument("no layer split values specified");
+    }
+
+    std::vector<int32_t> result;
+    result.reserve(split_arg.size());
+    for (const auto & part : split_arg) {
+        if (part.empty()) {
+            throw std::invalid_argument("empty layer split value");
+        }
+
+        size_t pos = 0;
+        const int value_i = std::stoi(part, &pos);
+        if (pos != part.size() || value_i < 0) {
+            throw std::invalid_argument("layer split values must be non-negative integers");
+        }
+        result.push_back(value_i);
+    }
+
+    return result;
+}
+
+static std::vector<float> parse_device_speed(const std::string & value) {
+    const std::regex regex{ R"([,/]+)" };
+    std::sregex_token_iterator it{ value.begin(), value.end(), regex, -1 };
+    std::vector<std::string> split_arg{ it, {} };
+    if (split_arg.empty()) {
+        throw std::invalid_argument("no device speed values specified");
+    }
+
+    std::vector<float> result;
+    result.reserve(split_arg.size());
+    for (const auto & part : split_arg) {
+        if (part.empty()) {
+            throw std::invalid_argument("empty device speed value");
+        }
+
+        size_t pos = 0;
+        const float value_f = std::stof(part, &pos);
+        if (pos != part.size() || value_f <= 0.0f) {
+            throw std::invalid_argument("device speed values must be positive numbers");
+        }
+        result.push_back(value_f);
+    }
+
+    return result;
+}
