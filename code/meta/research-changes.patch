+    return ggml_view_4d(
+            ctx,
+            src,
+            ne0,
+            src->ne[1],
+            src->ne[2],
+            src->ne[3],
+            src->nb[1],
+            src->nb[2],
+            src->nb[3],
+            begin0 * src->nb[0]);
+}
