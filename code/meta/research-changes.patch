+static const char * llama_stage5_phase_name(int64_t n_q, uint32_t n_kv_prev, uint32_t n_tail_kv) {
+    if (n_q == 1) {
+        return "decode";
+    }
+    if (n_kv_prev == 0) {
+        return "prefill";
+    }
+    if (n_tail_kv > 0) {
