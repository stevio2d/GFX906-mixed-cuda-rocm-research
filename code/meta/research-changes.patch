+static inline int ggml_cuda_fattn_env_int(const char * name, const int default_value) {
+    const char * value = getenv(name);
+    if (value == nullptr || value[0] == '\0') {
+        return default_value;
+    }
+
+    char * end = nullptr;
+    const long parsed = strtol(value, &end, 10);
+    if (end == value) {
+        return default_value;
+    }
+
+    return parsed > INT32_MAX ? INT32_MAX : (parsed < INT32_MIN ? INT32_MIN : (int) parsed);
