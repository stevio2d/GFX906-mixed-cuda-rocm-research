+            dev[id].dst_for_scatter = dst_sorted;
+        }
+    }
+
+    ctx.device = main_device;
+    ggml_cuda_set_device(main_device);
+    for (int id = 0; id < ggml_backend_cuda_get_device_count(); ++id) {
+        if (dev[id].compact_rows == 0) {
+            continue;
+        }
+
+        if (id != main_device) {
+            CUDA_CHECK(cudaStreamWaitEvent(main_stream, src0_extra->events[id][stream_no], 0));
+        }
+
+        ggml_cuda_moe_scatter_rows_f32(dev[id].dst_for_scatter, dev[id].dst_rows_for_scatter, (float *) dst->data, ne0, dev[id].compact_rows, main_stream);
