+    static const int min_rows = ggml_cuda_moe_profile_env_int("GGML_CUDA_MOE_PROFILE_MIN_ROWS", 32);
+    static const int max_calls = ggml_cuda_moe_profile_env_int("GGML_CUDA_MOE_PROFILE_MAX_CALLS", 0);
+
+    if (profile_enabled == 0) {
+        return;
+    }
+
+    if (n_rows < min_rows) {
+        return;
