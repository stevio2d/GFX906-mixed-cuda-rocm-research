+static __global__ void k_moe_scatter_rows_f32(
+        const float * src, const int32_t * dst_rows, float * dst, int64_t ncols, int64_t nrows) {
+    const int64_t i = (int64_t) blockIdx.x*blockDim.x + threadIdx.x;
+    const int64_t n = ncols*nrows;
+
+    if (i >= n) {
+        return;
+    }
+
+    const int64_t col = i % ncols;
+    const int64_t row = i / ncols;
+    dst[(int64_t) dst_rows[row]*ncols + col] = src[row*ncols + col];
+}
+
+static void ggml_cuda_moe_scatter_rows_f32(
+        const float * src, const int32_t * dst_rows, float * dst, int64_t ncols, int64_t nrows, cudaStream_t stream) {
+    if (nrows == 0) {
+        return;
+    }
+
+    const int64_t n = ncols*nrows;
+    const int block_size = 256;
+    const dim3 block_dims(block_size, 1, 1);
+    const dim3 grid_dims((n + block_size - 1) / block_size, 1, 1);
+    k_moe_scatter_rows_f32<<<grid_dims, block_dims, 0, stream>>>(src, dst_rows, dst, ncols, nrows);
+    CUDA_CHECK(cudaGetLastError());
+}
+
+static __global__ void k_gather_rows_f32(
+        const float * src, const int32_t * rows, float * dst, int64_t nrows) {
+    const int64_t i = (int64_t) blockIdx.x*blockDim.x + threadIdx.x;
+    if (i >= nrows) {
+        return;
+    }
+    dst[i] = src[rows[i]];
+}
+
+static void ggml_cuda_gather_rows_f32(
+        const float * src, const int32_t * rows, float * dst, int64_t nrows, cudaStream_t stream) {
+    if (nrows == 0) {
+        return;
+    }
+
+    const int block_size = 256;
+    const dim3 block_dims(block_size, 1, 1);
+    const dim3 grid_dims((nrows + block_size - 1) / block_size, 1, 1);
+    k_gather_rows_f32<<<grid_dims, block_dims, 0, stream>>>(src, rows, dst, nrows);
+    CUDA_CHECK(cudaGetLastError());
+}
+
+static __global__ void k_moe_weighted_accum_tokens_f32(
+        const float * src,
+        const float * weights,
+        const int32_t * dst_rows,
+        float * dst,
+        int64_t ncols,
+        int64_t nrows,
+        int topk) {
+    const int64_t i = (int64_t) blockIdx.x*blockDim.x + threadIdx.x;
+    const int64_t n = ncols*nrows;
+
+    if (i >= n) {
+        return;
+    }
+
+    const int64_t col = i % ncols;
+    const int64_t row = i / ncols;
+    const int64_t token = dst_rows[row] / topk;
+    atomicAdd(&dst[token*ncols + col], src[row*ncols + col] * weights[row]);
+}
+
+static void ggml_cuda_moe_weighted_accum_tokens_f32(
+        const float * src,
+        const float * weights,
+        const int32_t * dst_rows,
+        float * dst,
+        int64_t ncols,
+        int64_t nrows,
+        int topk,
+        cudaStream_t stream) {
+    if (nrows == 0) {
+        return;
+    }
+
+    const int64_t n = ncols*nrows;
+    const int block_size = 256;
+    const dim3 block_dims(block_size, 1, 1);
+    const dim3 grid_dims((n + block_size - 1) / block_size, 1, 1);
+    k_moe_weighted_accum_tokens_f32<<<grid_dims, block_dims, 0, stream>>>(src, weights, dst_rows, dst, ncols, nrows, topk);
+    CUDA_CHECK(cudaGetLastError());
+}
+
+static __global__ void k_add_f32(
+        const float * src, float * dst, int64_t n) {
+    const int64_t i = (int64_t) blockIdx.x*blockDim.x + threadIdx.x;
+    if (i >= n) {
+        return;
+    }
+    dst[i] += src[i];
+}
+
+static void ggml_cuda_add_f32(
+        const float * src, float * dst, int64_t n, cudaStream_t stream) {
+    if (n == 0) {
+        return;
+    }
+
+    const int block_size = 256;
+    const dim3 block_dims(block_size, 1, 1);
+    const dim3 grid_dims((n + block_size - 1) / block_size, 1, 1);
+    k_add_f32<<<grid_dims, block_dims, 0, stream>>>(src, dst, n);
+    CUDA_CHECK(cudaGetLastError());
+}
