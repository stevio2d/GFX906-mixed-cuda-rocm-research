+    if (min_value >= 0 && value < min_value) {
+        return false;
+    }
+
+    const int max_value = ggml_cuda_fattn_env_int(name_max, -1);
+    if (max_value >= 0 && value > max_value) {
+        return false;
+    }
+
+    return true;
+}
+
+static inline bool ggml_cuda_fattn_common_env_range_configured(const char * name_min, const char * name_max) {
