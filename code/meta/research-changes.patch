+static int ggml_backend_sched_next_nonzero_copy(ggml_backend_sched_t sched, int copy_id) {
+    if (sched->n_copies <= 1) {
+        return 0;
+    }
+
+    for (int i = 0; i < sched->n_copies; ++i) {
+        const int candidate = (copy_id + i) % sched->n_copies;
+        if (candidate != 0) {
+            return candidate;
+        }
+    }
+
+    return copy_id;
+}
